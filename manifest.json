{
  "manifest_version": 3,
  "name": "Browser-Color-Picker",
  "version": "3.0",
  "description": "Browser Color Picker - pick colors from any webpage",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Browser Color Picker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "windows"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon-16.png", "icons/icon-48.png", "icons/icon-128.png"],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
